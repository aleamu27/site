{
  "functions": {
    "api/chat.js": {
      "maxDuration": 30
    },
    "api/contact.js": {
      "maxDuration": 10
    },
    "api/blog.js": {
      "maxDuration": 10
    },
    "api/upload-image.js": {
      "maxDuration": 30
    },
    "api/blog-edit.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/static/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
} 